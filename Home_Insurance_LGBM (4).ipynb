        "\n",
        "if len(results_df) > 0:\n",
        "    plt.figure(figsize=(14, 5))\n",
        "    plt.plot(results_df[\"pair_idx\"], results_df[\"covariate_drift\"], marker=\"o\")\n",
        "    plt.title(\"Covariate Drift Across Pairs\")\n",
        "    plt.xlabel(\"Pair Index\")\n",
        "    plt.ylabel(\"Mean Wasserstein Distance\")\n",
        "    plt.grid(True)\n",
        "    plt.show()\n",
        "\n",
        "    plt.figure(figsize=(14, 5))\n",
        "    plt.plot(results_df[\"pair_idx\"], results_df[\"target_drift\"], marker=\"o\")\n",
