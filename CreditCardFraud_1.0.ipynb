    "# We reuse: feature_names, shap_values_train, shap_values_test, train_df, test_df\n",
    "# and we assume hourly_importance has already been computed as in your WRMS+ code:\n",
    "# hourly_importance = shap_df.groupby('Hour')[feature_names].apply(lambda x: x.abs().mean())\n",
    "\n",
    "print(f\"Aggregated SHAP values over {len(hourly_importance)} hours.\")\n",
    "\n",
    "# -------------------------------\n",
    "# 1. Weighted PSI function\n",
    "# -------------------------------\n",
    "def weighted_psi_expl(s_A, s_B, eps=1e-8):\n",
    "    \"\"\"\n",
    "    Weighted PSI between two global importance vectors s_A and s_B.\n",
    "    s_A, s_B : pd.Series, index=feature names, values=mean |SHAP| in period A/B\n",
    "\n",
    "    Returns:\n",
    "        wPSI (float): higher => more explanation drift (0 = identical distributions)\n",
    "    \"\"\"\n",
    "    # Normalize to probabilities over features\n",
    "    p_A = s_A / s_A.sum()\n",
    "    p_B = s_B / s_B.sum()\n",
    "\n",
    "    # Rank weights based on reference A (rank 1 = most important)\n",
    "    ranks_A = s_A.rank(ascending=False, method='min')\n",
    "    w = 1.0 / np.log2(1.0 + ranks_A)  # smooth decreasing weights\n",
    "\n",
    "    # PSI component per feature:\n",
    "    # (p_B - p_A) * log( p_B / p_A )\n",
    "    # add eps to avoid division by zero / log(0)\n",
    "    diff = p_B - p_A\n",
    "    log_ratio = np.log((p_B + eps) / (p_A + eps))\n",
    "    psi_i = diff * log_ratio\n",
    "\n",
    "    # Weighted PSI (normalize by sum of weights)\n",
    "    wPSI = np.sum(w * psi_i) / np.sum(w)\n",
    "\n",
    "    return wPSI\n",
    "\n",
    "\n",
    "# -------------------------------\n",
    "# 2. Compute wPSI over time\n",
    "# -------------------------------\n",
    "hours = sorted(hourly_importance.index.unique())\n",
    "wps_consecutive_data = []\n",
    "wps_baseline_data = []\n",
    "\n",
    "# Baseline is the first hour\n",
    "h_base = hours[0]\n",
    "s_base = hourly_importance.loc[h_base]\n",
    "\n",
    "for i in range(len(hours)):\n",
    "    h_curr = hours[i]\n",
    "    s_curr = hourly_importance.loc[h_curr]\n",
    "\n",
    "    # A. Consecutive comparison: hour t vs hour t+1\n",
    "    if i < len(hours) - 1:\n",
    "        h_next = hours[i+1]\n",
    "        s_next = hourly_importance.loc[h_next]\n",
    "\n",
    "        wpsi = weighted_psi_expl(s_curr, s_next)\n",
    "        wps_consecutive_data.append({\n",
    "            \"Hour_A\": h_curr,\n",
    "            \"Hour_B\": h_next,\n",
    "            \"wPSI\": wpsi\n",
    "        })\n",
    "\n",
    "    # B. Baseline comparison: hour 0 vs hour t\n",
    "    if h_curr != h_base:\n",
    "        wpsi_base = weighted_psi_expl(s_base, s_curr)\n",
    "        wps_baseline_data.append({\n",
    "            \"Hour_Current\": h_curr,\n",
    "            \"wPSI\": wpsi_base\n",
    "        })\n",
    "\n",
    "df_wps_consecutive = pd.DataFrame(wps_consecutive_data)\n",
    "df_wps_baseline = pd.DataFrame(wps_baseline_data)\n",
    "\n",
    "print(\"Weighted PSI calculations complete.\")\n",
    "\n",
    "\n",
    "# -------------------------------\n",
    "# 3. Optional: convert to stability score\n",
    "#     stability = exp(-wPSI)\n",
    "# -------------------------------\n",
    "df_wps_consecutive[\"Stability\"] = np.exp(-df_wps_consecutive[\"wPSI\"])\n",
    "df_wps_baseline[\"Stability\"] = np.exp(-df_wps_baseline[\"wPSI\"])\n",
