    "# 1. Compute Global Feature Importance (Mean Absolute SHAP)\n",
    "fi_train = np.abs(shap_values_train).mean(axis=0)\n",
    "fi_test = np.abs(shap_values_test).mean(axis=0)\n",
    "\n",
    "# Create a DataFrame to compare\n",
    "fi_df = pd.DataFrame({\n",
    "    'Feature': X_train.columns,\n",
    "    'SHAP_Train': fi_train,\n",
    "    'SHAP_Test': fi_test\n",
    "})\n",
    "\n",
    "# Add Rankings\n",
    "fi_df['Rank_Train'] = fi_df['SHAP_Train'].rank(ascending=False)\n",
    "fi_df['Rank_Test'] = fi_df['SHAP_Test'].rank(ascending=False)\n",
    "\n",
    "# 2. Spearman Correlation\n",
    "spearman_corr = fi_df[['Rank_Train', 'Rank_Test']].corr(method='spearman').iloc[0, 1]\n",
    "print(f\"Spearman Rank Correlation (Global Stability): {spearman_corr:.4f}\")\n",
    "\n",
    "# 3. Jaccard Similarity (Top-K)\n",
    "def jaccard_similarity(list1, list2):\n",
    "    s1 = set(list1)\n",
    "    s2 = set(list2)\n",
    "    return len(s1.intersection(s2)) / len(s1.union(s2))\n",
    "\n",
    "k = 5\n",
    "top_k_train = fi_df.sort_values('Rank_Train').head(k)['Feature'].values\n",
    "top_k_test = fi_df.sort_values('Rank_Test').head(k)['Feature'].values\n",
    "\n",
    "jaccard_score = jaccard_similarity(top_k_train, top_k_test)\n",
    "print(f\"Jaccard Similarity (Top-{k}): {jaccard_score:.4f}\")\n",
    "print(f\"Top {k} Train: {top_k_train}\")\n",
    "print(f\"Top {k} Test:  {top_k_test}\")\n",
    "\n",
    "# Display the comparison\n",
    "fi_df.sort_values('Rank_Train').head(10)"
   ]
