    "# 2. Define Parameter Grid\n",
    "param_dist = {\n",
    "    'max_depth': [2, 3, 4, 5, 6],          # Lower depth reduces overfitting\n",
    "    'learning_rate': [0.01, 0.05, 0.1],    # Lower rate is more robust\n",
    "    'n_estimators': [100, 200, 300],       # More trees (with low LR) is good\n",
    "    'min_child_weight': [1, 3, 5],         # Higher values prevent learning from outliers\n",
    "    'gamma': [0, 0.1, 0.5],                # Minimum loss reduction required to make a split\n",
    "    'reg_alpha': [0, 0.1, 1.0],            # L1 regularization\n",
