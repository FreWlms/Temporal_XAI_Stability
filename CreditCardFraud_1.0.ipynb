    "from scipy.stats import wasserstein_distance\n",
    "\n",
    "# 1. Calculate Drift Scores (PSI & Wasserstein)\n",
    "drift_results = []\n",
    "\n",
    "print(\"Calculating advanced drift metrics (PSI & Wasserstein)...\")\n",
    "\n",
    "for feature in X_train.columns:\n",
    "    # 1.1 Covariate Drift (Global: All Train vs All Test)\n",
    "    d1 = X_train[feature]\n",
    "    d2 = X_test[feature]\n",
    "    \n",
    "    psi_global = calculate_psi(d1, d2)\n",
    "    wd_global = wasserstein_distance(d1, d2)\n",
    "    \n",
    "    # 1.2 Class 0 Drift (Normal Day 1 vs Normal Day 2)\n",
    "    d1_0 = X_train[y_train == 0][feature]\n",
    "    d2_0 = X_test[y_test == 0][feature]\n",
    "    \n",
    "    psi_normal = calculate_psi(d1_0, d2_0)\n",
    "    wd_normal = wasserstein_distance(d1_0, d2_0)\n",
    "    \n",
    "    # 1.3 Class 1 Drift (Fraud Day 1 vs Fraud Day 2)\n",
    "    d1_1 = X_train[y_train == 1][feature]\n",
    "    d2_1 = X_test[y_test == 1][feature]\n",
