    "def calculate_psi(expected, actual, buckets=10):\n",
    "    '''Calculate the Population Stability Index (PSI) for a single variable'''\n",
    "    \n",
    "    def scale_range (input, min, max):\n",
    "        input += -(np.min(input))\n",
    "        input /= np.max(input) / (max - min)\n",
    "        input += min\n",
    "        return input\n",
    "\n",
    "    breakpoints = np.arange(0, buckets + 1) / (buckets) * 100\n",
    "    \n",
    "    if expected.nunique() > buckets:\n",
    "        breakpoints = np.percentile(expected, breakpoints)\n",
    "    else:\n",
    "        # For categorical/low cardinality, just use unique values\n",
    "        breakpoints = np.array(sorted(expected.unique()))\n",
    "        # Add a small epsilon to edges to ensure coverage\n",
    "        breakpoints = np.concatenate(([breakpoints[0]-0.001], breakpoints[1:]+0.001))\n",
    "\n",
    "    # Handle case where breakpoints are not unique (e.g. many zeros)\n",
    "    breakpoints = np.unique(breakpoints)\n",
    "    \n",
    "    # Calculate frequencies\n",
    "    expected_percents = np.histogram(expected, breakpoints)[0] / len(expected)\n",
    "    actual_percents = np.histogram(actual, breakpoints)[0] / len(actual)\n",
    "\n",
    "    # Avoid division by zero\n",
    "    expected_percents = np.where(expected_percents == 0, 0.0001, expected_percents)\n",
    "    actual_percents = np.where(actual_percents == 0, 0.0001, actual_percents)\n",
    "\n",
    "    psi_value = np.sum((actual_percents - expected_percents) * np.log(actual_percents / expected_percents))\n",
    "    return psi_value\n",
    "\n",
    "def analyze_drift(train_df, test_df, features):\n",
    "    results = []\n",
    "    \n",
    "    for feature in features:\n",
    "        # KS Test\n",
    "        ks_stat, ks_p_value = stats.ks_2samp(train_df[feature], test_df[feature])\n",
    "        \n",
    "        # PSI\n",
    "        psi = calculate_psi(train_df[feature], test_df[feature], buckets=10)\n",
    "        \n",
    "        results.append({\n",
    "            'Feature': feature,\n",
    "            'KS_Stat': ks_stat,\n",
    "            'KS_P_Value': ks_p_value,\n",
    "            'PSI': psi\n",
    "        })\n",
    "        \n",
    "    return pd.DataFrame(results).sort_values(by='PSI', ascending=False)\n",
    "\n",
    "# Select features (V1-V28 and Amount)\n",
    "features_to_check = [col for col in df.columns if col not in ['Time', 'Class']]\n",
    "\n",
    "drift_report = analyze_drift(train_df, test_df, features_to_check)\n",
    "\n",
    "# Display top drifting features\n",
    "print(\"Top features by Drift Magnitude (PSI):\")\n",
    "drift_report.head(10)\n",
    "\n",
    "# P_values become useless in large datasets: probability is pushed to zero because of the large number of observations\n",
    "# PSI > 0.20 is often deemed significant, so at first glance there is global data drift present."
   ]
  },
