    "    scoring='average_precision', # Optimize for AUPRC\n",
    "    cv=tscv,\n",
    "    verbose=1,\n",
    "    n_jobs=-1,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "print(\"Starting Time-Series Hyperparameter Search...\")\n",
    "# We search ONLY on the Training set (First 24 hours). \n",
