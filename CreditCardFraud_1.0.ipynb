    "# Dynamic Feature Importance Analysis\n",
    "# We investigate how the model's reliance on features changes hour-by-hour.\n",
    "\n",
    "# Build Hourly Importance Matrix\n",
    "# Concatenate SHAP values (Day 1 + Day 2)\n",
    "all_shap = np.vstack([shap_values_train, shap_values_test])\n",
    "all_times = pd.concat([train_df['Time'], test_df['Time']]).values\n",
    "feature_names = X_train.columns\n",
    "\n",
    "# Create a DataFrame linking Time to SHAP values\n",
    "shap_time_df = pd.DataFrame(all_shap, columns=feature_names)\n",
    "shap_time_df['Time'] = all_times\n",
    "shap_time_df['Abs_Hour'] = np.floor(shap_time_df['Time'] / 3600).astype(int)\n",
    "\n",
    "# Group by Hour and Calculate Mean |SHAP| (Feature Importance)\n",
    "# Result: Rows = Hours (0-47), Cols = Features, Values = Importance\n",
    "hourly_importance = shap_time_df.groupby('Abs_Hour')[feature_names].apply(lambda x: x.abs().mean())\n",
    "\n",
    "# Generate Rankings\n",
    "# Rank 1 = Most Important\n",
    "hourly_ranks = hourly_importance.rank(axis=1, ascending=False)\n",
    "\n",
    "print(\"Hourly Feature Ranking (First 5 Hours):\")\n",
    "display(hourly_ranks.head())\n",
    "\n",
    "# Plot Top 5 Fluctuations\n",
    "# Identify the Global Top 5 (based on overall mean importance)\n",
    "global_top_5 = hourly_importance.mean().nlargest(5).index.tolist()\n",
    "print(f\"Global Top 5 Features: {global_top_5}\")\n",
    "\n",
    "plt.figure(figsize=(14, 8))\n",
    "\n",
    "# Plot lines\n",
    "for feature in global_top_5:\n",
    "    plt.plot(hourly_importance.index, hourly_ranks[feature], marker='o', linewidth=2, label=feature)\n",
    "\n",
    "# Styling\n",
    "plt.title('Evolution of Feature Importance (Top 5) Over 48 Hours', fontsize=16)\n",
    "plt.ylabel('Feature Importance (Mean |SHAP|)', fontsize=12)\n",
    "plt.xlabel('Time (Hours since start)', fontsize=12)\n",
    "plt.axvline(x=24, color='black', linestyle='--', alpha=0.5, label='Day Boundary')\n",
    "plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left', title=\"Top Features\")\n",
    "plt.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
