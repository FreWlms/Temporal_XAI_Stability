    "\n",
    "for i in range(len(hours)):\n",
    "    h_curr = hours[i]\n",
    "    s_curr = hourly_importance.loc[h_curr]\n",
    "    \n",
    "    # A. Consecutive Comparison (Compare h_curr with h_next)\n",
    "    if i < len(hours) - 1:\n",
    "        h_next = hours[i+1]\n",
    "        s_next = hourly_importance.loc[h_next]\n",
    "        \n",
    "        wrms_val = calculate_wrms_plus(s_curr, s_next)\n",
