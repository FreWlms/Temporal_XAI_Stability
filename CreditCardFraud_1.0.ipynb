    "# ---------------------------------------------------------\n",
    "# WRMS+ STABILITY ANALYSIS\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. Aggregation of SHAP Values by Hour\n",
    "# We combine train and test SHAP values to cover the full 48-hour period.\n",
    "\n",
    "# Ensure we have feature names\n",
    "feature_names = X_train.columns.tolist()\n",
    "\n",
    "# Stack SHAP values (Train followed by Test)\n",
    "# Note: shap_values_train/test are numpy arrays\n",
    "shap_values_all = np.vstack([shap_values_train, shap_values_test])\n",
    "\n",
    "# Get corresponding Time values\n",
    "# We concatenate the Time columns from the original DataFrames in the same order\n",
    "time_all = pd.concat([train_df['Time'], test_df['Time']], axis=0).values\n",
    "\n",
    "# Create a DataFrame for easier processing\n",
    "shap_df = pd.DataFrame(shap_values_all, columns=feature_names)\n",
    "shap_df['Time'] = time_all\n",
    "shap_df['Hour'] = (shap_df['Time'] // 3600).astype(int)\n",
    "\n",
    "# Calculate Global SHAP Importance per Hour (s_{A,i})\n",
    "# s_{A,i} = mean(|SHAP value of feature i in hour A|)\n",
    "hourly_importance = shap_df.groupby('Hour')[feature_names].apply(lambda x: x.abs().mean())\n",
    "\n",
    "print(f\"Aggregated SHAP values over {len(hourly_importance)} hours.\")\n",
    "\n",
    "\n",
    "# 2. Define WRMS+ Metric Function\n",
    "def calculate_wrms_plus(s_A, s_B):\n",
    "    \"\"\"\n",
    "    Calculates WRMS+ between two importance vectors s_A and s_B.\n",
    "    s_A, s_B: Series (index=feature_names, values=importance)\n",
    "    \"\"\"\n",
    "    # Normalize importances (p_{A,i} = s_{A,i} / sum(s_A))\n",
    "    p_A = s_A / s_A.sum()\n",
    "    p_B = s_B / s_B.sum()\n",
    "    \n",
    "    # Calculate Rank Weights based on Period A\n",
    "    # rank 1 = highest importance.\n",
    "    # We use method='min' to assign the same rank to ties (e.g. 1, 1, 3)\n",
    "    ranks_A = s_A.rank(ascending=False, method='min')\n",
    "    \n",
    "    # Weight formula: w_i = 1 / log2(1 + rank_{A,i})\n",
    "    w = 1 / np.log2(1 + ranks_A)\n",
    "    \n",
    "    # WRMS+ Formula\n",
    "    # WRMS+ = 1 - ( sum( w * |pA - pB| ) / sum( w * (pA + pB) ) )\n",
    "    \n",
    "    numerator = np.sum(w * np.abs(p_A - p_B))\n",
    "    denominator = np.sum(w * (p_A + p_B))\n",
    "    \n",
    "    if denominator == 0:\n",
    "        return np.nan\n",
    "        \n",
    "    return 1 - (numerator / denominator)\n",
    "\n",
    "\n",
    "# 3. Calculate WRMS+ Over Time\n",
    "\n",
    "hours = sorted(hourly_importance.index.unique())\n",
    "wrms_consecutive_data = []\n",
