    "def plot_selected_features_over_time_aggregated(df):\n",
    "    features = ['V3', 'V1', 'V28', 'V25']\n",
    "    df_agg = df.copy()\n",
    "    df_agg['Minute'] = (df_agg['Time'] // (60*10)).astype(int)\n",
    "    agg_df = df_agg.groupby('Minute')[features].mean().reset_index()\n",
    "    plt.figure(figsize=(14, 8))\n",
    "    for feature in features:\n",
    "        plt.plot(agg_df['Minute'], agg_df[feature], label=feature)\n",
    "    plt.xlabel('Time (10 minutes)')\n",
    "    plt.ylabel('Mean Feature Value')\n",
    "    plt.title('Aggregated Features V3, V1, V28, V25 over Time (per 10 minutes)')\n",
    "    plt.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "plot_selected_features_over_time_aggregated(df)"
   ]
  },
