    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 0. Build SHAP dataframe with hour information\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "# Stack SHAP values (train + test) in time order\n",
    "shap_values_all = np.vstack([shap_values_train, shap_values_test])\n",
    "time_all = pd.concat([train_df[\"Time\"], test_df[\"Time\"]], axis=0).values\n",
    "\n",
    "feature_names = X_train.columns.tolist()\n",
    "\n",
    "shap_df = pd.DataFrame(shap_values_all, columns=feature_names)\n",
    "shap_df[\"Time\"] = time_all\n",
    "\n",
    "# Convert seconds -> hour index (0,1,2,...)\n",
    "shap_df[\"Hour\"] = (shap_df[\"Time\"] // 3600).astype(int)\n",
    "\n",
    "print(f\"Data covers {shap_df['Hour'].min()} to {shap_df['Hour'].max()} hours.\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 1. Metric from the document: relative drift with top-k union\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "def explanation_drift_metric(s_A, s_B, top_k=10, eps=1e-12):\n",
    "    \"\"\"\n",
    "    Drift metric D(A,B) as described in the stability document.\n",
    "\n",
    "    s_A, s_B : pd.Series of global importances (mean |SHAP|) indexed by feature name.\n",
    "\n",
    "    Steps:\n",
    "    - Determine top-k features in A and B.\n",
    "    - Take union U.\n",
    "    - For i in U:\n",
    "        d_i = |s_A - s_B| / (s_A + s_B)\n",
    "    - Combined importance c_i = s_A + s_B (symmetric).\n",
    "    - Rank features by c_i (desc), weights w_i = 1/log2(1 + rank_i).\n",
    "    - D = sum(w_i * d_i) / sum(w_i)\n",
    "\n",
    "    Returns:\n",
    "        D (float): 0 = no drift, 1 = high drift on important features.\n",
    "    \"\"\"\n",
    "\n",
    "    # Top-k in A and B\n",
    "    top_A = s_A.nlargest(top_k).index\n",
    "    top_B = s_B.nlargest(top_k).index\n",
    "    U = top_A.union(top_B)\n",
    "\n",
    "    sA = s_A.reindex(U).fillna(0.0)\n",
    "    sB = s_B.reindex(U).fillna(0.0)\n",
    "\n",
    "    # Relative drift per feature\n",
    "    denom = sA + sB + eps\n",
    "    d = (sA - sB).abs() / denom\n",
    "\n",
    "    # Combined importance and ranks (symmetric)\n",
    "    c = sA + sB\n",
    "    ranks = c.rank(ascending=False, method=\"min\")  # 1 = most important\n",
    "\n",
    "    # Rank weights\n",
    "    w = 1.0 / np.log2(1.0 + ranks)\n",
    "\n",
    "    # Weighted average drift\n",
    "    D = np.sum(w * d) / np.sum(w)\n",
    "\n",
    "    return D\n",
    "\n",
    "\n",
    "def strict_stability(D):\n",
    "    \"\"\"\n",
    "    'Strenge stabiliteit met wortel' (one possible form):\n",
    "    Stability in [0,1], 1 = perfect stability.\n",
    "    \"\"\"\n",
    "    D = np.clip(D, 0.0, 1.0)\n",
    "    return 1.0 - np.sqrt(D)\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 2. Compute drift for different window sizes\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "WINDOW_SIZES = [1, 3, 10, 24]  # in hours\n",
    "TOP_K = 10\n",
    "\n",
    "# Dictionary: window_size -> DataFrame with drift per consecutive window pair\n",
    "drift_results = {}\n",
    "\n",
    "for W in WINDOW_SIZES:\n",
    "    # Assign each row to a \"window\" based on integer division of hours\n",
    "    # For example, W=3 -> windows 0: hours 0-2, 1: hours 3-5, ...\n",
    "    shap_df[f\"Window_{W}h\"] = (shap_df[\"Hour\"] // W).astype(int)\n",
    "\n",
    "    # Global SHAP importance per window (mean |SHAP|)\n",
    "    window_importance = (\n",
    "        shap_df\n",
    "        .groupby(f\"Window_{W}h\")[feature_names]\n",
    "        .apply(lambda x: x.abs().mean())\n",
    "    )\n",
    "\n",
    "    windows = sorted(window_importance.index.unique())\n",
    "\n",
    "    records = []\n",
    "    for i in range(len(windows) - 1):\n",
    "        wA = windows[i]\n",
    "        wB = windows[i + 1]\n",
    "\n",
    "        s_A = window_importance.loc[wA]\n",
    "        s_B = window_importance.loc[wB]\n",
    "\n",
    "        D = explanation_drift_metric(s_A, s_B, top_k=TOP_K)\n",
    "        S_strict = strict_stability(D)\n",
    "\n",
    "        records.append({\n",
    "            \"Window_A\": wA,\n",
    "            \"Window_B\": wB,\n",
    "            \"Drift\": D,\n",
    "            \"Stability_strict\": S_strict\n",
    "        })\n",
    "\n",
    "    drift_results[W] = pd.DataFrame(records)\n",
    "\n",
    "    print(f\"Window size {W}h -> {len(records)} drift measurements.\")\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------\n",
    "# 3. Plot drift for each window size\n",
    "# ---------------------------------------------------------\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(16, 10))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for ax, W in zip(axes, WINDOW_SIZES):\n",
    "    df_drift = drift_results[W]\n",
    "\n",
    "    if df_drift.empty:\n",
    "        ax.set_title(f\"{W}h windows (no pairs)\")\n",
    "        ax.axis(\"off\")\n",
    "        continue\n",
    "\n",
    "    # x-axis: Window_B (the later window in each pair)\n",
    "    ax.plot(df_drift[\"Window_B\"], df_drift[\"Drift\"],\n",
    "            marker=\"o\", linestyle=\"-\", label=\"Drift D(A,B)\")\n",
    "\n",
    "    # Optionally also plot strict stability:\n",
    "    # ax2 = ax.twinx()\n",
    "    # ax2.plot(df_drift[\"Window_B\"], df_drift[\"Stability_strict\"],\n",
    "    #          marker=\"x\", linestyle=\"--\", color=\"green\", label=\"Strict Stability\")\n",
    "\n",
    "    ax.set_title(f\"Explanation Drift per Consecutive Window (W = {W}h)\")\n",
    "    ax.set_xlabel(\"Window index (B)\")\n",
    "    ax.set_ylabel(\"Drift (0 = stable, 1 = high drift)\")\n",
    "    ax.grid(True, alpha=0.3)\n",
    "    ax.set_ylim(0, 1.05)\n",
    "\n",
    "    ax.legend(loc=\"upper right\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
