    "import shap\n",
    "\n",
    "# 1. Initialize Explainer\n",
    "# TreeExplainer is fast for trees. We don't need a background dataset for 'tree_path_dependent' (default),\n",
    "# but providing one makes it 'interventional' (more theoretically sound).\n",
    "# However, for speed on this large dataset, standard TreeExplainer is fine.\n",
    "explainer = shap.TreeExplainer(best_model)\n",
    "\n",
    "# 2. Calculate SHAP values\n",
    "\n",
    "# Drop non-features\n",
    "X_train = train_df.drop(cols_to_drop, axis=1)\n",
    "X_test = test_df.drop(cols_to_drop, axis=1)\n",
    "\n",
    "print(f\"Generating SHAP values for {len(X_train)} train samples and {len(X_test)} test samples...\")\n",
