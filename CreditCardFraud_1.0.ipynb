    "from imblearn.over_sampling import SMOTE\n",
    "from imblearn.under_sampling import RandomUnderSampler\n",
    "from imblearn.pipeline import Pipeline as ImbPipeline\n",
    "from sklearn.model_selection import RandomizedSearchCV\n",
    "\n",
    "# 1. Comparison Dictionary to store best models\n",
    "# We start with the Baseline we already optimized in Phase 2\n",
    "best_models = {\n",
    "    'Baseline (Weighted)': best_model # From Phase 2\n",
    "}\n",
    "\n",
    "# 2. Define the Search Space (Same as Phase 2, but NO scale_pos_weight)\n",
    "# Note: In a Pipeline, we prefix params with the step name (e.g., 'model__max_depth')\n",
    "param_grid_sampling = {\n",
    "    'model__max_depth': [2, 3, 4, 5, 6],\n",
    "    'model__learning_rate': [0.01, 0.05, 0.1],\n",
    "    'model__n_estimators': [100, 200, 300],\n",
    "    'model__min_child_weight': [1, 3, 5],\n",
    "    'model__gamma': [0, 0.1, 0.5],\n",
    "    'model__reg_alpha': [0, 0.1, 1.0],\n",
    "    'model__reg_lambda': [1, 1.5, 2.0],\n",
    "    # We do NOT include scale_pos_weight here, as sampling handles the ratio\n",
    "}\n",
    "\n",
    "# 3. Define the Strategies (Pipelines without the Classifier yet)\n",
    "# We will inject the classifier during the grid search definition\n",
    "strategies_to_optimize = {\n",
    "    'Undersampling': [\n",
    "        ('sampler', RandomUnderSampler(sampling_strategy=0.3, random_state=42)),\n",
    "        ('model', xgb.XGBClassifier(n_jobs=-1, random_state=42, eval_metric='logloss'))\n",
    "    ],\n",
    "    'Oversampling (SMOTE)': [\n",
    "        ('sampler', SMOTE(sampling_strategy=0.5, random_state=42)),\n",
    "        ('model', xgb.XGBClassifier(n_jobs=-1, random_state=42, eval_metric='logloss'))\n",
    "    ],\n",
    "    'Hybrid (SMOTE + Under)': [\n",
    "        ('over', SMOTE(sampling_strategy=0.2, random_state=42)),\n",
    "        ('under', RandomUnderSampler(sampling_strategy=0.5, random_state=42)),\n",
    "        ('model', xgb.XGBClassifier(n_jobs=-1, random_state=42, eval_metric='logloss'))\n",
    "    ]\n",
    "}\n",
    "\n",
    "print(f\"Starting Hyperparameter Optimization for {len(strategies_to_optimize)} new strategies...\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "tscv = TimeSeriesSplit(n_splits=3)\n",
    "\n",
    "for name, steps in strategies_to_optimize.items():\n",
    "    print(f\"\\nOptimization: {name}...\")\n",
    "    \n",
    "    # Create Pipeline\n",
    "    pipeline = ImbPipeline(steps)\n",
    "    \n",
    "    # Setup Search\n",
    "    search = RandomizedSearchCV(\n",
    "        estimator=pipeline,\n",
    "        param_distributions=param_grid_sampling,\n",
    "        n_iter=50,\n",
    "        scoring='average_precision',\n",
    "        cv=tscv,\n",
    "        n_jobs=-1,\n",
    "        verbose=1,\n",
    "        random_state=42\n",
    "    )\n",
    "    \n",
    "    # Fit on Train (Day 1)\n",
    "    search.fit(X_train, y_train)\n",
    "    \n",
    "    print(f\"  > Best CV Score: {search.best_score_:.4f}\")\n",
    "    print(f\"  > Best Params: {search.best_params_}\")\n",
    "    \n",
    "    best_models[name] = search.best_estimator_\n",
    "\n",
    "# 4. Final Evaluation on Test Set (Day 2)\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"FINAL RESULTS: Comparison on Unseen Future Data (Day 2)\")\n",
    "print(f\"{'Strategy':<30} | {'Test AUPRC':<15}\")\n",
    "print(\"-\" * 50)\n",
    "\n",
    "results_final = []\n",
    "\n",
    "for name, model in best_models.items():\n",
    "    # Predict\n",
    "    y_pred = model.predict_proba(X_test)[:, 1]\n",
    "    score = average_precision_score(y_test, y_pred)\n",
    "    \n",
    "    results_final.append({'Strategy': name, 'Test AUPRC': score})\n",
    "    print(f\"{name:<30} | {score:.4f}\")\n",
    "\n",
    "# Plot\n",
    "df_res = pd.DataFrame(results_final).sort_values('Test AUPRC', ascending=False)\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.barplot(data=df_res, y='Strategy', x='Test AUPRC', palette='viridis')\n",
    "plt.title('Final Model Comparison (Optimized)')\n",
    "plt.xlim(0, 1.0)\n",
    "plt.show()"
   ]
