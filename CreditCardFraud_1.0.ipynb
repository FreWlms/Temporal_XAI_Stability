   "source": [
    "# Prepare Data (Reconstruct Timeline from Phase 2 Split)\n",
    "# We need to look at the FULL timeline, so we concat Train + Test.\n",
    "# Note: We are strictly analyzing the DATA here, not model performance, so peeking at Test distribution is valid.\n",
    "\n",
    "full_analysis_df = pd.concat([train_df, test_df])\n",
    "full_analysis_df['Abs_Hour'] = full_analysis_df['Time'].apply(lambda x: np.floor(x / 3600))\n",
    "\n",
    "# Aggregations\n",
    "hourly_stats = full_analysis_df.groupby('Abs_Hour').agg({\n",
    "    'Hour': 'mean',\n",
    "    'Class': 'sum' # Sum of 1s = Count of Frauds\n",
    "}).rename(columns={'Class': 'Fraud_Count'})\n",
    "\n",
    "# 9.2 Plot Timeline\n",
    "fig, ax1 = plt.subplots(figsize=(14, 6))\n",
    "\n",
    "# Dual Axis Plot\n",
    "color_v12 = 'tab:blue'\n",
    "ax1.set_xlabel('Time (Hours since start)')\n",
    "ax1.set_ylabel('Average Hour Value', color=color_v12, fontsize=12)\n",
    "ax1.plot(hourly_stats.index, hourly_stats['Hour'], color=color_v12, marker='o', linewidth=2, label='Avg Hour Value')\n",
    "ax1.tick_params(axis='y', labelcolor=color_v12)\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# Mark the Day Boundary (24h)\n",
    "ax1.axvline(x=24, color='gray', linestyle='--', alpha=0.8, label='Day Boundary')\n",
    "\n",
    "# Fraud Count (Right Axis)\n",
    "ax2 = ax1.twinx()\n",
    "color_fraud = 'tab:red'\n",
    "ax2.set_ylabel('Fraud Count', color=color_fraud, fontsize=12)\n",
    "ax2.bar(hourly_stats.index, hourly_stats['Fraud_Count'], color=color_fraud, alpha=0.4, label='Fraud Count')\n",
    "ax2.tick_params(axis='y', labelcolor=color_fraud)\n",
    "\n",
    "plt.title('V2 Deep Dive: Feature Value vs. Criminal Activity', fontsize=16)\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n"
   ]
  },
